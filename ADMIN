<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Panel de Administración | JHT Ingeniería</title>
    <style>
        body { font-family: 'Segoe UI', Arial, sans-serif; background-color: #1b222c; color: #fff; padding: 40px; margin: 0; }
        .admin-container { max-width: 800px; margin: 0 auto; background: #242f3d; padding: 30px; border-radius: 8px; box-shadow: 0 4px 15px rgba(0,0,0,0.3); border-top: 4px solid #ff5722; }
        h1 { font-size: 24px; margin-bottom: 5px; color: #ff5722; text-transform: uppercase; }
        .sub { color: #aab7c4; font-size: 14px; margin-bottom: 30px; }
        .row { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 20px; }
        .box { background: #1c2530; padding: 15px; border-radius: 6px; border: 1px solid #34455a; }
        label { display: block; font-size: 13px; font-weight: bold; margin-bottom: 8px; color: #5dade2; }
        input[type="text"] { width: 100%; padding: 10px; background: #2c3b4e; border: 1px solid #415671; color: #fff; border-radius: 4px; box-sizing: border-box; }
        input[type="file"] { color: #ccc; font-size: 12px; }
        .btn-save { display: block; width: 100%; background: #25d366; color: white; border: none; padding: 14px; font-size: 16px; font-weight: bold; border-radius: 4px; cursor: pointer; margin-top: 25px; transition: background 0.3s; }
        .btn-save:hover { background: #1da851; }
        .status-msg { text-align: center; color: #25d366; font-weight: bold; margin-top: 15px; display: none; }
        .preview-indicator { font-size: 11px; color: #888; margin-top: 5px; }
    </style>
</head>
<body>

    <div class="admin-container">
        <h1>Panel de Configuración JHT</h1>
        <div class="sub">Modifica la información general y carga contenido multimedia para la página web pública principal.</div>

        <!-- SECCIÓN TEXTOS -->
        <h3>1. Datos de Contacto y Ubicación</h3>
        <div class="row">
            <div class="box">
                <label for="edit-direccion">Dirección Física de la Empresa:</label>
                <input type="text" id="edit-direccion" placeholder="Ej: Av. Industrial 123, Callao, Lima - Perú">
            </div>
            <div class="box">
                <label for="edit-mapa">Enlace Compartido de Google Maps (URL):</label>
                <input type="text" id="edit-mapa" placeholder="Ej: https://maps.google.com/...">
            </div>
        </div>

        <!-- SECCIÓN ARCHIVOS -->
        <h3>2. Carga de Imágenes y Videos para las Secciones</h3>
        <div class="row">
            <div class="box"><label>Fondo Principal (Hero - Inicio):</label><input type="file" id="u-hero" accept="image/*,video/*"></div>
            <div class="box"><label>Tarjeta 1: Corte Láser Fibra:</label><input type="file" id="u-s1" accept="image/*,video/*"></div>
        </div>
        <div class="row">
            <div class="box"><label>Tarjeta 2: Plegado CNC:</label><input type="file" id="u-s2" accept="image/*,video/*"></div>
            <div class="box"><label>Tarjeta 3: Soldadura Industrial:</label><input type="file" id="u-s3" accept="image/*,video/*"></div>
        </div>
        <div class="row">
            <div class="box"><label>Tarjeta 4: Fabricación Estructuras:</label><input type="file" id="u-s4" accept="image/*,video/*"></div>
            <div class="box"><label>Tarjeta 5: Planos CAD y Modelado:</label><input type="file" id="u-s5" accept="image/*,video/*"></div>
        </div>
        <div class="row">
            <div class="box" style="grid-column: span 2;"><label>Tarjeta 6: Servicios de Mecanizado:</label><input type="file" id="u-s6" accept="image/*,video/*"></div>
        </div>

        <button class="btn-save" id="btn-guardar">💾 GUARDAR CAMBIOS EN LA WEB</button>
        <div class="status-msg" id="msg-exito">✔ ¡Cambios guardados con éxito! Actualiza tu pestaña de index.html para verlos.</div>
    </div>

    <script>
    document.addEventListener('DOMContentLoaded', () => {
        // Cargar valores iniciales si ya existen
        if(localStorage.getItem('jht_direccion')) {
            document.getElementById('edit-direccion').value = localStorage.getItem('jht_direccion');
        }
        if(localStorage.getItem('jht_mapa')) {
            document.getElementById('edit-mapa').value = localStorage.getItem('jht_mapa');
        }

        const btnGuardar = document.getElementById('btn-guardar');
        const msgExito = document.getElementById('msg-exito');

        btnGuardar.addEventListener('click', async () => {
            // Guardar textos
            const dirValor = document.getElementById('edit-direccion').value;
            const mapaValor = document.getElementById('edit-mapa').value;
            
            localStorage.setItem('jht_direccion', dirValor);
            localStorage.setItem('jht_mapa', mapaValor);

            // Procesar los archivos multimedia seleccionados
            const inputsMultimedia = ['u-hero', 'u-s1', 'u-s2', 'u-s3', 'u-s4', 'u-s5', 'u-s6'];
            
            for (const id of inputsMultimedia) {
                const input = document.getElementById(id);
                if (input && input.files[0]) {
                    const file = input.files[0];
                    const base64 = await convertirABase64(file);
                    
                    const objMedia = {
                        tipo: file.type,
                        base64: base64
                    };
                    localStorage.setItem('jht_media_' + id, JSON.stringify(objMedia));
                }
            }

            // Mostrar mensaje de éxito
            msgExito.style.display = 'block';
            setTimeout(() => { msgExito.style.display = 'none'; }, 4000);
        });

        // Función útil para convertir los archivos a texto Base64 almacenable
        function convertirABase64(file) {
            return new Promise((resolve, reject) => {
                const reader = new FileReader();
                reader.readAsDataURL(file);
                reader.onload = () => resolve(reader.result);
                reader.onerror = error => reject(error);
            });
        }
    });
    </script>
</body>
</html>
